# ============================================================
#  NexusSec — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Replace ALL placeholder values with strong, unique secrets.
#  3. NEVER commit the real .env to version control.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=nexussec
POSTGRES_PASSWORD=CHANGE_ME_strong_pg_password
POSTGRES_DB=nexussec_db
POSTGRES_PORT=5432

# ── MongoDB ─────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=nexussec
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_strong_mongo_password
MONGO_INITDB_DATABASE=nexussec_reports
MONGO_PORT=27017

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_PORT=6379

# ── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=nexussec
RABBITMQ_DEFAULT_PASS=CHANGE_ME_strong_rabbitmq_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ── JWT (RS256 — Asymmetric) ───────────────────────────────
# Generate keys:
#   openssl genrsa -out keys/private.pem 4096
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_EXPIRATION=24h
JWT_ISSUER=nexussec
JWT_REFRESH_DURATION=168h

# ── Scanner / Worker Service ───────────────────────────────
# SCAN_NETWORK must match the network name defined in docker-compose.yml
# so the worker can attach ephemeral scan containers to it.
SCAN_NETWORK=scan-network
SCANNER_CONCURRENCY=3
PROXY_TIMEOUT=5s

# ── OAuth & Frontend ───────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=https://nexussec.me